INSTALL_ROOT=/opt/vllm-monitor

PROMETHEUS_VERSION=3.11.1
PROMETHEUS_URL=https://github.com/prometheus/prometheus/releases/download/v3.11.1/prometheus-3.11.1.linux-amd64.tar.gz
