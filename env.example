PROMETHEUS_PORT=9090
PROMETHEUS_JOB_PREFIX=vllm
METRICS_SERVICES_FILE=services.example.tsv
OFFLINE_BUNDLE_DIR=dist
ALLOW_DOWNLOAD=false

GRAFANA_VERSION=12.4.1
GRAFANA_URL=https://dl.grafana.com/grafana-enterprise/release/12.4.1/grafana-enterprise_12.4.1_22846628243_linux_amd64.tar.gz
