          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by(policy) (rate(vllm_router_policy_decisions_total{service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{policy}}",
          "refId": "A"
        }
      ],
      "title": "Policy Decision Distribution",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "id": 400,
      "panels": [],
      "title": "Worker Health & Circuit Breaker",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Circuit breaker state per worker. 0 = closed (healthy), 1 = half-open (testing), 2 = open (tripped, requests blocked). Any non-zero state requires immediate attention.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "green",
                  "index": 0,
